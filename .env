# Authentication
JWT_SECRET="savr-track-secret-change-in-production-2024"

# Cron Job Protection
CRON_API_KEY="savr-cron-key"

# App URL (used in email notification links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email Notifications (SMTP - Gmail)
# IMPORTANT: SMTP_HOST must be the mail server, NOT your email address
# IMPORTANT: SMTP_PASS must be a Gmail App Password, NOT your regular password
# Steps to get App Password:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification (required)
#   3. Go to App passwords (search "app passwords" in Google Account)
#   4. Create one for "Mail" → copy the 16-character password
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="elitemobilexx@gmail.com"
SMTP_PASS=""
SMTP_FROM="notifications@surevia.vercel.app"

# Document Encryption (AES-256-GCM)
DOCUMENT_ENCRYPTION_KEY="a8f2c9e1b4d7f0a3c6e9b2d5f8a1c4e7"

# SMS Notifications (Twilio) - Optional, leave empty to skip
